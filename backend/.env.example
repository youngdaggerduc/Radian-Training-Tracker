# Copy this file to .env and fill in real values before starting the server.
# Never commit .env — it is gitignored.

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-a-64-char-random-string

# PostgreSQL connection string (from Render or Neon)
# Format: postgresql://user:password@host/dbname
DATABASE_URL=postgresql://user:password@host/dbname

# Comma-separated list of allowed frontend origins (no trailing slash)
# Set to your Vercel URL in production
ALLOWED_ORIGINS=https://your-app.vercel.app
